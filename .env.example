
# ============================================================
# Hackathon Starter — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local
#
# Never commit .env.local to version control.
# ============================================================

# --- Supabase (Required) ------------------------------------
# Find these in: Supabase Dashboard → Project Settings → API

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous (public) key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- OpenAI (Required for style transformation) -------------
OPENAI_API_KEY=sk-...

# --- Supabase Admin (Optional — server-only) ----------------
# Only needed if you use service role in Route Handlers or Server Actions.
# NEVER expose this key to the browser or prefix with NEXT_PUBLIC_.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
